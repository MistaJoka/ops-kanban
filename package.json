{
  "name": "ops-kanban-ai-mvp",
  "version": "0.1.0",
  "private": true,
  "description": "AI-first landscaping operations Kanban — blueprint + starter",
  "scripts": {
    "dev": "next dev",
    "predev": "node scripts/warn-prod-cache.mjs",
    "dev:clean": "node scripts/dev-clean.mjs",
    "postbuild": "node scripts/warn-prod-cache.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:ui": "playwright test --ui",
    "test:ai": "vitest run tests/unit/ai.test.ts tests/unit/context-utils.test.ts tests/integration/ai-command.test.ts",
    "test:security": "vitest run tests/integration/rls-matrix.test.ts",
    "test:webhooks": "vitest run tests/integration/payment-webhook.test.ts",
    "test:sms": "vitest run tests/integration/sms-webhook.test.ts tests/integration/booking.test.ts",
    "test:sign": "vitest run tests/integration/sign-webhook.test.ts",
    "test:wave4": "vitest run tests/integration/wave4.test.ts",
    "test:a11y": "playwright test --grep @a11y",
    "test:release": "npm run check:no-mock && npm run check:doc-sync && npm run test:unit && npm run test:ai && npm run test:integration && npm run test:security && npm run build",
    "test:regression": "npm run test:release && npm run test:e2e && npm run test:a11y",
    "test:seed": "tsx scripts/test-seed.ts",
    "dev:reset-board": "tsx scripts/reset-dev-board.ts",
    "db:migrate": "tsx scripts/apply-migrations.ts",
    "check:no-mock": "bash scripts/check-no-mock.sh",
    "check:css-health": "node scripts/check-css-health.mjs",
    "check:slop-health": "node scripts/check-slop-health.mjs",
    "check:doc-sync": "node scripts/check-doc-sync.mjs",
    "check:slop": "npm run check:slop-health && npm run check:no-mock && npm run format:check",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/generative-ai": "^0.21.0",
    "@sentry/nextjs": "^10.53.1",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.47.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "next": "^15.5.18",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "server-only": "^0.0.1",
    "shadcn": "^4.8.0",
    "stripe": "^22.1.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.7",
    "autoprefixer": "^10.5.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "pg": "^8.21.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
